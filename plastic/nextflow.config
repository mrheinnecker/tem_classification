params {
    main_dir       = "C:/projects/plastic_screen"
    input_table    = "C:/projects/plastic_screen/plastic_images.tsv"
    sheet_mode     = "local"
    sheet_url      = ""
    sheet_name     = ""
    google_key     = "$projectDir/trec-tem-screen-e98a2e03f58b.json"
    collection_table_url = ""
    collection_table_sheet = "plastic_collection_table"
    local_collection_table = "C:/projects/plastic_screen/plastic_collection_table.tsv"
    outdir         = "C:/projects/plastic_screen/processed"
    logdir         = "C:/projects/plastic_screen/logs/wfPLASTIC_local"
    script_dir     = "$projectDir"
    dryrun         = "TRUE"
    dryrun_n       = 2
    workflow_stage = "discover"

    container_tidyverse = "/g/schwab/marco/container_devel/probeDesign_rtool.sif"
    container_eubi      = "/g/schwab/marco/container_devel/eubibridge.sif"
    container_mc        = "/g/schwab/marco/container_devel/EMBL_mc_2024-05-03T11-21-07Z.sif"
    container_lif       = "/g/schwab/marco/container_devel/lif_metadata.sif"

    s3_bucket = "s3embl/plastictest"
    zarr_format = 2
    default_x_scale = ""
    default_y_scale = ""
    default_z_scale = ""
    scale_unit = "nm"
    persistent_metadata_dir = "C:/projects/plastic_screen/metadata"
    eubi_extra_args = ""
}

process {
    withName:CHECKEXISTINGPLASTICS3FILES {
        container = "${params.container_mc}"
        executor = "local"
    }
    withName:SELECTPLASTICIMAGES {
        container = "${params.container_tidyverse}"
        executor = "local"
    }
    withName:EXTRACTPLASTICMETADATA {
        container = "${params.container_lif}"
    }
    withName:EUBIPLASTICCONVERSION {
        container = "${params.container_eubi}"
    }
    withName:PATCHPLASTICOMEZARRMETADATA {
        container = "${params.container_lif}"
    }
    withName:S3UPLOADPLASTIC {
        container = "${params.container_mc}"
        executor = "local"
    }
    withName:COLLECTPLASTICS3FILES {
        container = "${params.container_mc}"
        executor = "local"
    }
    withName:MAKEPLASTICCOLLECTIONTABLE {
        container = "${params.container_tidyverse}"
        executor = "local"
    }
}

singularity {
    enabled = false
}

profiles {
    local {
        executor.name = "local"
        singularity.enabled = false
        params.workflow_stage = "discover"
        params.sheet_mode = "local"
        params.dryrun = "TRUE"
    }

    interactive {
        executor.name = "local"
        singularity.enabled = true
        params.main_dir = "/scratch/rheinnec/plastic_screen"
        params.input_table = "/scratch/rheinnec/plastic_screen/plastic_images.tsv"
        params.outdir = "/scratch/rheinnec/plastic_screen/processed"
        params.logdir = "/scratch/rheinnec/plastic_screen/logs/wfPLASTIC_interactive"
        params.script_dir = "/g/schwab/marco/repos/tem_classification/plastic"
        params.persistent_metadata_dir = "/g/schwab/marco/central_data_processing/plastic/metadata"
        params.workflow_stage = "process"
        params.sheet_mode = "google"
        params.dryrun = "FALSE"
    }

    cluster {
        singularity.enabled = true
        executor.name = "slurm"
        executor.perTaskReserve = false
        executor.perJobMemLimit = true
        executor.queueSize = 30
        executor.submitRateLimit = "3 sec"

        params.main_dir = "/scratch/rheinnec/plastic_screen"
        params.input_table = "/scratch/rheinnec/plastic_screen/plastic_images.tsv"
        params.outdir = "/scratch/rheinnec/plastic_screen/processed"
        params.logdir = "/scratch/rheinnec/plastic_screen/logs/wfPLASTIC_cluster"
        params.script_dir = "/g/schwab/marco/repos/tem_classification/plastic"
        params.persistent_metadata_dir = "/g/schwab/marco/central_data_processing/plastic/metadata"
        params.workflow_stage = "all"
        params.sheet_mode = "google"
        params.dryrun = "FALSE"
    }
}
