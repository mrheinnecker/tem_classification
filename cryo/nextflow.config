params {
    main_dir       = "C:/projects/cryo_screen"
    input_table    = "C:/projects/cryo_screen/cryo_images.tsv"
    sheet_mode     = "local"
    sheet_url      = ""
    sheet_name     = ""
    google_key     = "$projectDir/trec-tem-screen-e98a2e03f58b.json"
    collection_table_url = ""
    collection_table_sheet = "cryo_collection_table"
    local_collection_table = "C:/projects/cryo_screen/cryo_collection_table.tsv"
    outdir         = "C:/projects/cryo_screen/processed"
    logdir         = "C:/projects/cryo_screen/logs/wfCRYO_local"
    script_dir     = "$projectDir"
    dryrun         = "TRUE"
    dryrun_n       = 2
    workflow_stage = "discover"

    container_tidyverse = "/g/schwab/marco/container_devel/probeDesign_rtool.sif"
    container_eubi      = "/g/schwab/marco/container_devel/eubibridge_czi.sif"
    container_mc        = "/g/schwab/marco/container_devel/EMBL_mc_2024-05-03T11-21-07Z.sif"
    container_python    = "/g/schwab/marco/container_devel/eubibridge_czi.sif"

    s3_bucket = "s3embl/cryotest"
    zarr_format = 2
    default_x_scale = ""
    default_y_scale = ""
    default_z_scale = ""
    scale_unit = "nm"
    persistent_metadata_dir = "C:/projects/cryo_screen/metadata"
}

process {
    withName:CHECKEXISTINGCRYOS3FILES {
        container = "${params.container_mc}"
        executor = "local"
    }
    withName:SELECTCRYOIMAGES {
        container = "${params.container_tidyverse}"
        executor = "local"
    }
    withName:EXTRACTCRYOMETADATA {
        container = "${params.container_python}"
    }
    withName:EUBICRYOCONVERSION {
        container = "${params.container_eubi}"
    }
    withName:S3UPLOADCRYO {
        container = "${params.container_mc}"
        executor = "local"
    }
    withName:COLLECTCRYOS3FILES {
        container = "${params.container_mc}"
        executor = "local"
    }
    withName:MAKECRYOCOLLECTIONTABLE {
        container = "${params.container_tidyverse}"
        executor = "local"
    }
}

singularity {
    enabled = false
}

profiles {
    local {
        executor.name = "local"
        singularity.enabled = false
        params.workflow_stage = "discover"
        params.sheet_mode = "local"
        params.dryrun = "TRUE"
    }

    interactive {
        executor.name = "local"
        singularity.enabled = true
        params.main_dir = "/scratch/rheinnec/cryo_screen"
        params.input_table = "/scratch/rheinnec/cryo_screen/cryo_images.tsv"
        params.outdir = "/scratch/rheinnec/cryo_screen/processed"
        params.logdir = "/scratch/rheinnec/cryo_screen/logs/wfCRYO_interactive"
        params.script_dir = "/g/schwab/marco/repos/tem_classification/cryo"
        params.persistent_metadata_dir = "/g/schwab/marco/central_data_processing/cryo/metadata"
        params.workflow_stage = "process"
        params.sheet_mode = "google"
        params.dryrun = "FALSE"
    }

    cluster {
        singularity.enabled = true
        executor.name = "slurm"
        executor.perTaskReserve = false
        executor.perJobMemLimit = true
        executor.queueSize = 30
        executor.submitRateLimit = "3 sec"

        params.main_dir = "/scratch/rheinnec/cryo_screen"
        params.input_table = "/scratch/rheinnec/cryo_screen/cryo_images.tsv"
        params.outdir = "/scratch/rheinnec/cryo_screen/processed"
        params.logdir = "/scratch/rheinnec/cryo_screen/logs/wfCRYO_cluster"
        params.script_dir = "/g/schwab/marco/repos/tem_classification/cryo"
        params.persistent_metadata_dir = "/g/schwab/marco/central_data_processing/cryo/metadata"
        params.workflow_stage = "all"
        params.sheet_mode = "google"
        params.dryrun = "FALSE"
    }
}
