params {
    main_dir       = "C:/projects/hitt_screen"
    input_table    = "C:/projects/hitt_screen/hitt_images.tsv"
    sheet_mode     = "local"
    sheet_url      = "https://docs.google.com/spreadsheets/d/1ePRpa56mmMvCeRTLXmwOywOLy5_I3AFrxJepSUYGR1s/edit?gid=0#gid=0"
    sheet_name     = ""
    google_key     = "$projectDir/trec-tem-screen-e98a2e03f58b.json"
    collection_table_url = "https://docs.google.com/spreadsheets/d/1ePRpa56mmMvCeRTLXmwOywOLy5_I3AFrxJepSUYGR1s/edit?gid=1582290308#gid=1582290308"
    collection_table_sheet = "hitt_collection_table"
    local_collection_table = "C:/projects/hitt_screen/hitt_collection_table.tsv"
    logdir         = "C:/projects/hitt_screen/logs/wfHITT_local"
    script_dir     = "$projectDir"
    dryrun         = "TRUE"
    dryrun_n       = 2
    workflow_stage = "discover"

    container_tidyverse = "/g/schwab/marco/container_devel/probeDesign_rtool.sif"
    container_eubi      = "/g/schwab/marco/container_devel/eubibridge.sif"
    container_mc        = "/g/schwab/marco/container_devel/EMBL_mc_2024-05-03T11-21-07Z.sif"
    container_python    = "/g/schwab/marco/container_legacy/python_latest.sif"

    s3_bucket   = "s3embl/hitttest"
    zarr_format = 2
    x_scale     = 100
    y_scale     = 100
    input_suffix = "recon_111_1/tomo"
    output_name = "omezarr"
    overwrite   = "TRUE"
    convert_uint16 = "TRUE"
    uint16_lower_percentile = 0.1
    uint16_upper_percentile = 99.9
    uint16_sample_values = 2000000
}

process {
    withName:SELECTHITTIMAGES {
        container = "${params.container_tidyverse}"
        executor = "local"
    }
    withName:EUBIHITTCONVERSION {
        container = "${params.container_eubi}"
    }
    withName:NORMALIZEHITTSLICES {
        container = "${params.container_python}"
    }
    withName:EXTRACTHITTIMAGESTATS {
        container = "${params.container_python}"
    }
    withName:S3UPLOADHITT {
        container = "${params.container_mc}"
        executor = "local"
    }
    withName:COLLECTHITTS3FILES {
        container = "${params.container_mc}"
        executor = "local"
    }
    withName:MAKEHITTCOLLECTIONTABLE {
        container = "${params.container_tidyverse}"
        executor = "local"
    }
}

singularity {
    enabled = false
}

profiles {
    local {
        executor.name = "local"
        singularity.enabled = false
        params.workflow_stage = "discover"
        params.sheet_mode = "local"
        params.dryrun = "TRUE"
    }

    interactive {
        executor.name = "local"
        singularity.enabled = true
        params.main_dir = "/scratch/rheinnec/hitt_screen"
        params.input_table = "/scratch/rheinnec/hitt_screen/hitt_images.tsv"
        params.logdir = "/scratch/rheinnec/hitt_screen/logs/wfHITT_interactive"
        params.script_dir = "/g/schwab/marco/repos/tem_classification/hitt"
        params.workflow_stage = "process"
        params.sheet_mode = "google"
        params.dryrun = "FALSE"
    }

    cluster {
        singularity.enabled = true
        executor.name = "slurm"
        executor.perTaskReserve = false
        executor.perJobMemLimit = true
        executor.queueSize = 30
        executor.submitRateLimit = "3 sec"

        params.main_dir = "/scratch/rheinnec/hitt_screen"
        params.input_table = "/scratch/rheinnec/hitt_screen/hitt_images.tsv"
        params.logdir = "/scratch/rheinnec/hitt_screen/logs/wfHITT_cluster"
        params.script_dir = "/g/schwab/marco/repos/tem_classification/hitt"
        params.workflow_stage = "all"
        params.sheet_mode = "google"
        params.dryrun = "FALSE"
    }
}
