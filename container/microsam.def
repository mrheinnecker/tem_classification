Bootstrap: docker
From: ubuntu:24.04

%labels
    Author "you"
    Description "Ubuntu 24.04 + Python 3.12 (venv) + micro_sam (from GitHub) + numpy + pillow + zarr + CPU PyTorch"
    Version "1.2"

%environment
    export VIRTUAL_ENV=/opt/venv
    export PATH=/opt/venv/bin:$PATH
    export PYTHONUNBUFFERED=1
    export MICROSAM_CACHEDIR=/opt/micro-sam-cache

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    # --- system deps ---
    apt-get update
    apt-get install -y --no-install-recommends \
        python3.12 python3.12-venv python3-pip \
        git ca-certificates build-essential \
        libgl1 libglib2.0-0
    rm -rf /var/lib/apt/lists/*

    # --- python venv ---
    python3.12 -m venv /opt/venv
    . /opt/venv/bin/activate
    pip install --upgrade pip

    # --- CPU-only PyTorch stack (official index) ---
    pip install --no-cache-dir torch torchvision torchaudio \
      --index-url https://download.pytorch.org/whl/cpu

    # --- core scientific stack ---
    pip install --no-cache-dir numpy pillow zarr \
        tqdm scikit-image scipy matplotlib h5py torch_em

    # --- micro_sam from GitHub ---
    pip install --no-cache-dir "micro-sam @ git+https://github.com/computational-cell-analytics/micro-sam"

    # Optional: headless OpenCV (often handy for I/O)
    pip install --no-cache-dir opencv-python-headless

    mkdir -p /opt/micro-sam-cache

%runscript
    exec /bin/bash -lc "python \"$@\""

%apprun python
    exec /bin/bash -lc "python \"$@\""

%test
    python - <<'PY'
import numpy as np
from PIL import Image, ImageOps
import zarr, tqdm, scipy, h5py, matplotlib, skimage
from micro_sam.automatic_segmentation import get_predictor_and_segmenter, automatic_instance_segmentation
print("All imports OK")
PY
