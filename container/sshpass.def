Bootstrap: docker
From: ubuntu:24.04

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y \
        rsync \
        openssh-client \
        sshpass \
        ca-certificates

    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export LC_ALL=C
    export LANG=C

%runscript
    exec "$@"